# --- Server-only (NOT exposed to the browser — no VITE_ prefix) ---
# The Vite client never sees these. They live in the Node sidecar (server/)
# which proxies Airtable calls and injects the PAT.
AIRTABLE_PAT=

# This contractor's three bases. Per-deployment values:
#   VEC  → CM=appMFSTnsHl5sZe2u FIN=app9kIY9bY0TIpp4B  OPS=appUcTt6OcaDfVCkV
#   DMSW → CM=appQQ6JDpq9J31IXQ FIN=appnHxpN55yxzBB1J  OPS=appmVBIY66RMbt25n
#   CBRS → CM=appZRA3YySLkZDrY8 FIN=appZjXCcsz0NhXx2H  OPS=appEc63Elao1R6yLc
AIRTABLE_CLAIMS_MASTER_BASE=
AIRTABLE_FINANCIALS_BASE=
AIRTABLE_REST_OPS_BASE=

# Optional: shared-secret header the proxy requires from the client until
# real session auth lands.
PROXY_SHARED_SECRET=

# --- Client-safe (the proxy origin only) ---
VITE_API_BASE_URL=/api
VITE_APP_PASSWORD=your_app_password
